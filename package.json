{
  "name": "@semore/mcp-commerce",
  "version": "0.4.2",
  "mcpName": "io.github.semorehq/mcp-commerce",
  "description": "Semore commerce MCP server — canonical 5 tools (search_product, get_product, create_cart, quote_checkout, submit_intent) per ADR-0062, with AP2 IntentMandate / CartMandate / PaymentMandate VC chain.",
  "license": "Apache-2.0",
  "author": "Semore Founding Team <semore.hq@gmail.com>",
  "homepage": "https://semore.net",
  "repository": {
    "type": "git",
    "url": "https://github.com/semorehq/mcp-commerce.git"
  },
  "bugs": {
    "url": "mailto:semore.hq@gmail.com"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "commerce",
    "semore",
    "ai-agents",
    "anthropic",
    "claude",
    "chatgpt",
    "ap2",
    "agent-payments",
    "verifiable-credentials"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tools/search-product": {
      "types": "./dist/tools/search-product.d.ts",
      "import": "./dist/tools/search-product.js"
    },
    "./tools/get-product": {
      "types": "./dist/tools/get-product.d.ts",
      "import": "./dist/tools/get-product.js"
    },
    "./tools/create-cart": {
      "types": "./dist/tools/create-cart.d.ts",
      "import": "./dist/tools/create-cart.js"
    },
    "./tools/quote-checkout": {
      "types": "./dist/tools/quote-checkout.d.ts",
      "import": "./dist/tools/quote-checkout.js"
    },
    "./tools/submit-intent": {
      "types": "./dist/tools/submit-intent.d.ts",
      "import": "./dist/tools/submit-intent.js"
    },
    "./tools/search": {
      "types": "./dist/tools/search.d.ts",
      "import": "./dist/tools/search.js"
    },
    "./tools/cart": {
      "types": "./dist/tools/cart.d.ts",
      "import": "./dist/tools/cart.js"
    },
    "./tools/order": {
      "types": "./dist/tools/order.d.ts",
      "import": "./dist/tools/order.js"
    },
    "./tools/policy": {
      "types": "./dist/tools/policy.d.ts",
      "import": "./dist/tools/policy.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
